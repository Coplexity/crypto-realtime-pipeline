KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_NAME=binance_trades
FASTAPI_PORT=8000

# ============================================
# BINANCE MULTI-PAIR CONFIGURATION
# ============================================

# Pair discovery mode:
#   hot       = Top volume pairs (USDT trading volume > min_volume)
#   all       = All USDT trading pairs
#   whitelist = Explicit whitelist (comma-separated)
BINANCE_PAIR_FILTER=hot

# Minimum trading volume threshold (in USDT) to include pair
# Only used when BINANCE_PAIR_FILTER=hot
# Default: 100000 (100k USDT 24h volume)
BINANCE_PAIR_MIN_VOLUME=100000

# Explicit pair whitelist (comma-separated, lowercase)
# Only used when BINANCE_PAIR_FILTER=whitelist
# Example: btcusdt,ethusdt,bnbusdt,adausdt,xrpusdt
BINANCE_PAIR_WHITELIST=

# Interval to refresh pair list (in seconds)
# Set to 0 to disable auto-refresh
# Default: 3600 (refresh every hour)
BINANCE_PAIR_UPDATE_INTERVAL=3600